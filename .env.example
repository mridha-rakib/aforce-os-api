NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
MONGODB_URI=mongodb://127.0.0.1:27017/aforce
CORS_ORIGIN=*
LOGGER_PROVIDER=dual
LOG_LEVEL=debug
AWS_REGION=us-east-1
AI_ENGINE_MODE=rules
REQUEST_BODY_LIMIT_MB=2
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

JWT_ACCESS_SECRET=change-me-local-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-local-refresh-secret-minimum-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

EMAIL_VERIFICATION_SECRET=change-me-local-email-secret-minimum-32-characters
EMAIL_VERIFICATION_TTL_SECONDS=86400
ADMIN_REGISTRATION_SECRET=change-me-local-admin-registration-secret

APP_WEB_URL=http://localhost:5173
APP_MOBILE_DEEP_LINK=aforce://auth
RESEND_API_KEY=
EMAIL_FROM=AForce <noreply@localhost>
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

POSTMAN_COLLECTION_NAME="AForce API"
POSTMAN_EXPORT_PATH=postman/aforce-api.collection.json
POSTMAN_API_KEY=
POSTMAN_COLLECTION_UID=
POSTMAN_WORKSPACE_ID=
